# Azure AI Services Configuration
# Copy this file to .env and fill in your values
# NEVER commit the actual .env file!

# Azure Subscription
AZURE_SUBSCRIPTION_ID=your-subscription-id
AZURE_RESOURCE_GROUP=your-resource-group
AZURE_REGION=eastus

# Azure AI Services
AZURE_AI_SERVICES_KEY=your-ai-services-key
AZURE_AI_SERVICES_ENDPOINT=https://your-resource.cognitiveservices.azure.com/

# Computer Vision
AZURE_COMPUTER_VISION_KEY=your-vision-key
AZURE_COMPUTER_VISION_ENDPOINT=https://your-vision.cognitiveservices.azure.com/

# Language Services
AZURE_LANGUAGE_KEY=your-language-key
AZURE_LANGUAGE_ENDPOINT=https://your-language.cognitiveservices.azure.com/

# Speech Services
AZURE_SPEECH_KEY=your-speech-key
AZURE_SPEECH_REGION=your-speech-region

# Azure OpenAI
AZURE_OPENAI_KEY=your-openai-key
AZURE_OPENAI_ENDPOINT=https://your-openai.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT_NAME=your-deployment-name
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# Search Services
AZURE_SEARCH_KEY=your-search-key
AZURE_SEARCH_ENDPOINT=https://your-search.search.windows.net
AZURE_SEARCH_INDEX_NAME=your-index-name

# Form Recognizer / Document Intelligence
AZURE_FORM_RECOGNIZER_KEY=your-form-key
AZURE_FORM_RECOGNIZER_ENDPOINT=https://your-form.cognitiveservices.azure.com/

# Storage (for some labs)
AZURE_STORAGE_CONNECTION_STRING=your-storage-connection-string
AZURE_STORAGE_CONTAINER_NAME=your-container-name

# Application Insights (optional, for monitoring)
APPLICATIONINSIGHTS_CONNECTION_STRING=your-app-insights-connection-string

# Other Settings
LOG_LEVEL=INFO
ENABLE_TELEMETRY=false
API_TIMEOUT_SECONDS=30